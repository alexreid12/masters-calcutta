NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ESPN Golf API — no API key needed, it's free and public
# Optionally pin the Masters event ID if auto-detection fails
# Find it at: https://site.api.espn.com/apis/site/v2/sports/golf/pga/scoreboard
# ESPN_MASTERS_EVENT_ID=401580123

# Cron job protection (set a random secret, add it to Vercel env vars too)
CRON_SECRET=

# Email Notifications via Resend (optional — sign up free at resend.com)
# Free tier: 100 emails/day, 3,000/month.
# For testing, Resend allows sending to your own address from onboarding@resend.dev.
# For production, verify your domain in the Resend dashboard and update the `from`
# address in src/lib/email.ts.
RESEND_API_KEY=re_your_key_here

# Your public app URL (used to generate deep-links in notification emails)
# Leave blank for local dev (defaults to http://localhost:3000)
# On Vercel this is set automatically via VERCEL_URL; override here if using a custom domain.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
